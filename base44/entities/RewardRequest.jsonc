{
  "name": "RewardRequest",
  "type": "object",
  "properties": {
    "student_id": {
      "type": "string",
      "description": "ID of the student"
    },
    "parent_id": {
      "type": "string",
      "description": "ID of the targeted parent for approval"
    },
    "reward_id": {
      "type": "string",
      "description": "ID of the reward"
    },
    "reward_title": {
      "type": "string",
      "description": "Reward title for display"
    },
    "coin_cost": {
      "type": "number",
      "description": "Coin cost at time of request"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "default": "pending"
    },
    "parent_response_message": {
      "type": "string",
      "description": "Parent's message on approval/rejection"
    }
  },
  "required": [
    "student_id",
    "parent_id",
    "reward_id",
    "reward_title",
    "coin_cost"
  ],
  "rls": {
    "create": {
      "$or": [
        {
          "data.student_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "app_role": "super_admin"
          }
        }
      ]
    },
    "read": {
      "$or": [
        {
          "data.student_id": "{{user.id}}"
        },
        {
          "data.parent_id": "{{user.id}}"
        },
        {
          "data.student_id": {
            "$in": "{{user.data.linked_student_ids}}"
          }
        },
        {
          "user_condition": {
            "app_role": {
              "$in": [
                "super_admin",
                "school_admin"
              ]
            }
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.parent_id": "{{user.id}}"
        },
        {
          "data.student_id": {
            "$in": "{{user.data.linked_student_ids}}"
          }
        },
        {
          "user_condition": {
            "app_role": "super_admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "app_role": "super_admin"
      }
    }
  }
}
