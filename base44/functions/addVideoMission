import { createClientFromRequest } from "npm:@base44/sdk@0.8.31";

const extractYouTubeId = (url: string): string | null => {
  const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
  const match = url.match(regExp);
  return (match && match[2].length === 11) ? match[2] : null;
};

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    
    // 1. Sahkan sesi log masuk pengguna semasa
    const currentUser = await base44.auth.me();
    if (!currentUser) {
      return Response.json({ success: false, error: "Unauthorized" }, { status: 401 });
    }

    // 🔐 DIBAIKI: Sekatan ketat, hanya role "admin" sahaja yang dibenarkan lepas
    if (currentUser.app_role !== "admin") {
      return Response.json({ 
        success: false, 
        error: "Akses disekat. Hanya pentadbir (Admin) sahaja yang mempunyai kebenaran untuk menguruskan misi video YouTube." 
      }, { status: 403 });
    }

    const { title, videoUrl, xpReward, educationLevel } = await req.json();

    if (!title || !videoUrl) {
      return Response.json({ success: false, error: "Tajuk dan Pautan Video wajib diisi." }, { status: 400 });
    }

    // 2. Ekstrak YouTube ID
    const youtubeId = extractYouTubeId(videoUrl);
    if (!youtubeId) {
      return Response.json({ success: false, error: "Pautan YouTube tidak sah. Sila semak semula URL video." }, { status: 400 });
    }

    // 3. Bina payload data menggunakan struktur rekod selamat (Kalis Linter Failure)
    const lessonPayload: Record<string, unknown> = {
      title: title.trim(),
      video_url: videoUrl.trim(),
      youtube_id: youtubeId,
      xp_reward: Number(xpReward) || 20,
      education_level: educationLevel || "Primary",
      created_by: currentUser.id,
      mission_type: "watch_video",
      status: "active",
      created_at: new Date().toISOString()
    };

    const newLesson = await base44.asServiceRole.entities.Lesson.create(lessonPayload);

    return Response.json({
      success: true,
      message: "Misi video YouTube berjaya didaftarkan oleh Admin!",
      lesson: {
        id: newLesson.id,
        title: newLesson.title,
        youtube_id: newLesson.youtube_id
      }
    });

  } catch (err) {
    const errorMsg = err instanceof Error ? err.message : String(err);
    console.error("Ralat addVideoMission:", errorMsg);
    return Response.json({ success: false, error: `Ralat Pelayan Backend: ${errorMsg}` }, { status: 500 });
  }
});
