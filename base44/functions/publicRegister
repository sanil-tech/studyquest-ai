import { createClientFromRequest } from "npm:@base44/sdk@0.8.31";

const hashPassword = (password: string) =>
  btoa(unescape(encodeURIComponent(`SQ_PWD_SALT_${password}_2026`)));

Deno.serve(async (req) => {
  try {
    const base44 = createClientFromRequest(req);
    const { username: rawUsername, password, role } = await req.json();

    // 1. Sanitasi dan semakan input
    const username = rawUsername?.trim().toLowerCase().replace(/[^a-z0-9_]/g, "");
    
    if (!username) {
      return Response.json({ success: false, error: "Username wajib diisi." }, { status: 400 });
    }
    if (!password || password.length < 6) {
      return Response.json({ success: false, error: "Kata laluan minimum 6 aksara." }, { status: 400 });
    }
    if (!role || !["parent", "student", "teacher"].includes(role)) {
      return Response.json({ success: false, error: "Peranan tidak sah." }, { status: 400 });
    }

    // 2. Semak jika username entiti sudah wujud
    const existing = await base44.asServiceRole.entities.User.filter({ username });
    if (existing.length > 0) {
      return Response.json({ success: false, error: "Username telah digunakan. Sila pilih nama lain." }, { status: 400 });
    }

    // Bina e-mel maya
    const childEmail = `${username}@studyquest.local`;
    const passwordHash = hashPassword(password);
    const studentId = "SQ" + Math.floor(100000 + Math.random() * 900000);

    // 3. Daftarkan akaun ke dalam Native Auth dengan status Terlanjur Sah (Bypass OTP)
    const authUser = await base44.asServiceRole.auth.createUser({
      email: childEmail,
      password: password,
      email_confirmed: true
    });

    if (!authUser || !authUser.id) {
      throw new Error("Gagal mendaftarkan kredensial pada auth provider.");
    }

    // 4. Cipta Profil Entiti Pengguna
    const userPayload: any = {
      id: authUser.id,
      role: "user",
      email: childEmail,
      full_name: username,
      app_role: role,
      username,
      password_hash: passwordHash,
      login_method: "username_password",
      is_child_account: role === "student",
      profile_completed: false,
      country: "Malaysia",
      account_locked: false,
      failed_login_attempts: 0
    };

    if (role === "student") {
      userPayload.student_id = studentId;
    }

    const newUser = await base44.asServiceRole.entities.User.create(userPayload);

    // 5. Sediakan Wallet & Progress jika mendaftar sebagai murid
    if (role === "student") {
      await base44.asServiceRole.entities.Wallet.create({ student_id: newUser.id, balance: 0 });
      await base44.asServiceRole.entities.Progress.create({ 
        student_id: newUser.id, 
        total_xp: 0, 
        level: 1, 
        streak_days: 0, 
        total_study_time: 0 
      });
    }

    return Response.json({ success: true, username: newUser.username });
  } catch (err) {
    console.error("Ralat publicRegister:", err);
    return Response.json({ success: false, error: err.message }, { status: 500 });
  }
});
